VITE_BASE=/

# 接口地址（打包进 dist/_app.config.js，仅匹配 VITE_GLOB_*）
# 与站点同域且 Nginx 反代 /api → 后端时用相对路径即可；跨域则写完整 https 地址
VITE_GLOB_API_URL=/api

# 是否开启压缩，可以设置为 none, brotli, gzip
VITE_COMPRESS=none

# 是否开启 PWA
VITE_PWA=false

# vue-router 的模式
VITE_ROUTER_HISTORY=hash

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 打包后是否生成dist.zip
VITE_ARCHIVER=true
